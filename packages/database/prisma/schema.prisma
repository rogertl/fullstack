// Prisma Schema - 合同管理系统数据库定义
// 契约优先：此文件将从 Zod Schema 生成，当前为初始模板

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

