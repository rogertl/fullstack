{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./.next",
    "rootDir": "./",
    "paths": {
      "@/*": ["./src/*"],
      "@contract-management/shared": ["../../packages/shared/src"],
      "@contract-management/types": ["../../packages/database/src"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
