{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./.next",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@contract-management/shared": [
        "../../packages/shared/src"
      ],
      "@contract-management/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@contract-management/types": [
        "../../packages/database/src"
      ]
    },
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ],
  "references": [
    {
      "path": "../../packages/shared"
    }
  ]
}
